# Copy this file to .env for local dev, and set the same keys (with
# production values) in the Render dashboard under your service's
# Environment tab. Never commit the real .env file.

# --- Server ---
PORT=5000
NODE_ENV=development
# Set to "true" in production (Render). Must be true for cross-site
# cookies (sameSite=none) to work between the Vercel frontend and this
# Render backend. Keep "false" for local dev over http://localhost.
COOKIE_SECURE=false

# --- Database (Render Postgres / Supabase / Neon, etc.) ---
# Must include ?sslmode=require in production for most managed Postgres providers.
DATABASE_URL=postgresql://user:password@localhost:5432/saas_auth_platform

# --- JWT / sessions ---
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN_DAYS=7

# --- Upstash Redis (used for rate limiting) ---
# From the Upstash console: your database's REST URL and REST token.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace-with-upstash-rest-token

# --- Resend (transactional email) ---
RESEND_API_KEY=re_replace_with_resend_api_key
# Must be a verified sender/domain in Resend.
EMAIL_FROM="Your App <noreply@yourdomain.com>"

# --- Frontend URL (CORS origin + links in emails) ---
# Local dev: http://localhost:5173
# Production: your Vercel deployment URL, e.g. https://your-app.vercel.app
CLIENT_URL=http://localhost:5173

# --- Google OAuth ---
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
# Must exactly match an Authorized redirect URI configured in Google Cloud Console.
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/oauth/google/callback

# --- GitHub OAuth ---
# https://github.com/settings/developers
GITHUB_CLIENT_ID=replace-with-github-client-id
GITHUB_CLIENT_SECRET=replace-with-github-client-secret
# Must exactly match the Authorization callback URL configured on the GitHub OAuth App.
GITHUB_CALLBACK_URL=http://localhost:5000/api/auth/oauth/github/callback
