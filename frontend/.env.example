# Copy this file to .env for local dev, and set the same key (with the
# production value) in the Vercel dashboard under Project Settings > Environment
# Variables. Vite only exposes variables prefixed with VITE_ to client code.

# Local dev: your backend's local URL, including the /api prefix.
# Production: your Render backend URL, including the /api prefix,
# e.g. https://your-backend.onrender.com/api
VITE_API_BASE_URL=http://localhost:5000/api
